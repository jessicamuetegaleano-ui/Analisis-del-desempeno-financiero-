/* ============================================================
   PROYECTO: Análisis de Ventas y Rentabilidad
   AUTOR: [Tu nombre]
   DESCRIPCIÓN:
   Este script realiza:
   1. Exploración de datos
   2. Limpieza y transformación
   3. Cálculo de KPIs financieros
   4. Validación de calidad de datos (QA)
============================================================ */

/* ============================================================
   PARTE 1: EXPLORACIÓN DE DATOS
   Objetivo: Revisar estructura y contenido inicial
============================================================ */

-- Vista previa tabla ventas
SELECT * FROM ventas_2017 LIMIT 10;

-- Vista previa productos
SELECT * FROM productos LIMIT 10;

-- Vista previa categorías
SELECT * FROM productos_categorias LIMIT 10;

-- Vista previa territorios
SELECT * FROM territorios LIMIT 10;

-- Vista previa campañas
SELECT * FROM campanas LIMIT 10;


/* ============================================================
   PARTE 2: LIMPIEZA Y TRANSFORMACIÓN
   Objetivo: Unificar datos y manejar valores nulos
============================================================ */

-- Creación de dataset limpio (vista o tabla temporal recomendada)
-- Integra ventas, productos, categorías y territorios

SELECT
    v.numero_pedido,
    v.clave_producto,
    p.nombre_producto,
    pc.clave_categoria,

    -- Limpieza de valores nulos
    COALESCE(p.precio_producto, 0)  AS precio_producto,
    COALESCE(v.cantidad_pedido, 0)  AS cantidad_pedido,
    COALESCE(p.costo_producto, 0)   AS costo_producto,

    t.pais,
    t.continente,
    v.clave_territorio

FROM ventas_2017 AS v

-- Unión con productos
LEFT JOIN productos AS p
    ON v.clave_producto = p.clave_producto

-- Unión con categorías
LEFT JOIN productos_categorias AS pc
    ON p.clave_subcategoria = pc.clave_subcategoria

-- Unión con territorios
LEFT JOIN territorios AS t
    ON v.clave_territorio = t.clave_territorio;


/* ============================================================
   PARTE 2.2: CÁLCULO DE INGRESOS Y COSTOS
   Objetivo: Crear métricas base del negocio
============================================================ */

SELECT
    v.numero_pedido,
    v.clave_producto,
    p.nombre_producto,
    pc.clave_categoria,

    COALESCE(p.precio_producto, 0)  AS precio_producto,
    COALESCE(v.cantidad_pedido, 0)  AS cantidad_pedido,
    COALESCE(p.costo_producto, 0)   AS costo_producto,

    t.pais,
    t.continente,
    v.clave_territorio,

    -- Cálculo de ingresos
    COALESCE(p.precio_producto,0) * COALESCE(v.cantidad_pedido,0) AS ingreso_total,

    -- Cálculo de costos
    COALESCE(p.costo_producto,0) * COALESCE(v.cantidad_pedido,0) AS costo_total

FROM ventas_2017 AS v

JOIN productos AS p
    ON v.clave_producto = p.clave_producto

LEFT JOIN productos_categorias AS pc
    ON p.clave_subcategoria = pc.clave_subcategoria

LEFT JOIN territorios AS t
    ON v.clave_territorio = t.clave_territorio;


/* ============================================================
   PARTE 3: KPIs FINANCIEROS
============================================================ */

-- NOTA: Se asume que el resultado anterior se guardó como:
-- tabla o vista: ventas_clean

/* ------------------------------------------------------------
   3.1 INGRESOS Y COSTOS POR PAÍS
------------------------------------------------------------ */

SELECT
    pais,
    clave_territorio,

    -- Suma de ingresos
    CAST(SUM(COALESCE(ingreso_total,0)) AS INTEGER) AS total_ingresos,

    -- Suma de costos
    CAST(SUM(COALESCE(costo_total,0)) AS INTEGER) AS costos_totales

FROM ventas_clean

GROUP BY pais, clave_territorio

ORDER BY total_ingresos DESC;


/* ------------------------------------------------------------
   3.2 INTEGRACIÓN DE CAMPAÑAS
------------------------------------------------------------ */

SELECT
    v.pais,
    v.clave_territorio,

    -- Métricas principales
    SUM(v.ingreso_total)::INTEGER AS ingresos,
    SUM(v.costo_total)::INTEGER  AS costos,

    -- Costo de campañas
    COALESCE(SUM(c.costo_campana)::INTEGER, 0) AS costo_campana

FROM ventas_clean AS v

LEFT JOIN campanas AS c
    ON v.clave_territorio = c.clave_territorio::INTEGER

GROUP BY v.pais, v.clave_territorio

ORDER BY ingresos DESC;


/* ------------------------------------------------------------
   3.3 KPIs AVANZADOS (ROI, MARGEN, BENEFICIO)
------------------------------------------------------------ */

-- Ejemplo conceptual (puedes ajustarlo según tu modelo final)

SELECT
    pais,
    clave_territorio,
    ingresos,
    costos,
    costo_campana,

    -- Beneficio bruto
    (ingresos - costos) AS beneficio_bruto,

    -- Margen (%)
    CASE 
        WHEN ingresos = 0 THEN 0
        ELSE ((ingresos - costos) * 100.0 / ingresos)
    END AS margen_pct,

    -- ROI (%)
    CASE 
        WHEN costo_campana = 0 THEN 0
        ELSE ((ingresos - costos - costo_campana) * 100.0 / costo_campana)
    END AS roi_pct

FROM pais_campanas;


/* ============================================================
   PARTE 4: VALIDACIÓN DE CALIDAD (QA)
============================================================ */

-- 4.1 Validación de nulos en claves principales

SELECT
    SUM(CASE WHEN numero_pedido IS NULL THEN 1 ELSE 0 END) AS nulos_numero_pedido,
    SUM(CASE WHEN clave_producto IS NULL THEN 1 ELSE 0 END) AS nulos_clave_producto,
    SUM(CASE WHEN clave_territorio IS NULL THEN 1 ELSE 0 END) AS nulos_clave_territorio
FROM ventas_2017;


-- 4.2 Validación de cantidades inválidas

SELECT
    COUNT(*) AS filas_cantidad_no_valida
FROM ventas_2017
WHERE cantidad_pedido <= 0;


-- 4.3 Validación de precios negativos

SELECT
    COUNT(*) AS productos_precio_no_valido
FROM productos
WHERE precio_producto < 0;


